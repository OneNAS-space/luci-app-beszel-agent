{
	"luci-app-beszel-agent": {
		"description": "Grant access to Beszel Agent configuration and service",
		"read": {
			"file": {
				"/usr/bin/beszel-agent --version": [ "exec" ]
			},
			"ubus": {
				"service": [ "list" ]
			},
			"uci": [ "beszel-agent" ]
		},
		"write": {
			"uci": [ "beszel-agent" ]
		}
	}
}
